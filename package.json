{
  "name": "finish-my-dinner",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.8.0",
  "scripts": {
    "format": "prettier --write \"{apps,packages,tests,scripts,.github}/**/*.{ts,tsx,js,mjs,json,yml,yaml}\" \"*.{json,yml,yaml}\"",
    "format:check": "prettier --check \"{apps,packages,tests,scripts,.github}/**/*.{ts,tsx,js,mjs,json,yml,yaml}\" \"*.{json,yml,yaml}\"",
    "lint": "pnpm --recursive --if-present lint",
    "typecheck": "pnpm --recursive --if-present typecheck",
    "test": "pnpm --recursive --if-present test",
    "assert:capabilities": "pnpm --filter @finish-my-dinner/web test -- runtime-config",
    "build": "pnpm --recursive --if-present build",
    "check": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test && pnpm build"
  },
  "devDependencies": {
    "@eslint/js": "9.39.1",
    "@types/node": "24.10.1",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.1",
    "globals": "16.5.0",
    "prettier": "3.7.4",
    "typescript": "5.9.3",
    "typescript-eslint": "8.50.0",
    "vitest": "4.0.15"
  }
}
